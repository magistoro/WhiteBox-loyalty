{
  "name": "whitebox",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/api"
  ],
  "scripts": {
    "db:generate": "prisma generate",
    "db:local:up": "docker compose up -d postgres",
    "db:local:down": "docker compose down",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:status": "prisma migrate status",
    "db:validate": "prisma validate",
    "db:seed": "node prisma/seed.mjs",
    "dev": "next dev",
    "dev:local": "node scripts/dev-local.mjs",
    "dev:web": "next dev",
    "build": "node scripts/railway-build.mjs",
    "build:web": "next build",
    "start": "node scripts/railway-start.mjs",
    "start:web": "next start",
    "lint": "eslint",
    "ci:verify": "npm run db:generate && npm run db:validate && npm run lint && npm run build:web && npm run api:build && npm run api:test",
    "api:dev": "npm run start:dev -w whitebox-api",
    "api:build": "npm run build -w whitebox-api",
    "api:start": "npm run start:prod -w whitebox-api",
    "api:test": "npm run test -w whitebox-api"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.17",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/qrcode": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.29.2",
    "jose": "^6.2.2",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "pg": "^8.20.0",
    "prisma": "^7.5.0",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "typescript": "^5"
  }
}
